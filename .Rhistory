scaled_gnp_lag2 = (gnp_lag2 - min(gnp_lag2)) / (max(gnp_lag2) - min(gnp_lag2))
)
ggplot(crash_window, aes(x = year)) +
geom_line(aes(y = scaled_articles, color = "Article Count"), linewidth = 1) +
