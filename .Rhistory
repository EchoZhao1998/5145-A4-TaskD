filter(year >= 2007 & year <= 2014) |>
filter(news_provider == "Irish Times") |>
arrange(year) |>
mutate(
gnp_lag2 = lag(annual_gnp, 2)
) |>
filter(!is.na(gnp_lag2)) |>
mutate(
